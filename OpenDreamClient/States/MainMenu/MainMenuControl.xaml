
<Control xmlns="https://spacestation14.io">
    <PanelContainer Name="Panel">
        <LayoutContainer>
            <AnimatedTextureRect Name="Background" />
            <BoxContainer Name="VBox"
                          Orientation="Vertical">
                <TextureRect Name="Logo"
                             Stretch="KeepCentered" />
                <BoxContainer Orientation="Vertical"
                              SetWidth="371"
                              HorizontalAlignment="Center">
                    <BoxContainer Orientation="Horizontal"
                                  SeparationOverride="4">
                        <Label Text="Username: " FontColorOverride="#C06C84" FontColorShadowOverride="#000000" ShadowOffsetXOverride="1" ShadowOffsetYOverride="1"/>
                        <LineEdit Name="UsernameBoxProtected"
                                  PlaceHolder="UngaBunga"
                                  HorizontalExpand="True" />
                    </BoxContainer>
                    <Control MinSize="0 2" />
                    <BoxContainer Orientation="Horizontal"
                                  SeparationOverride="4">
                        <Label Text="Server: " FontColorOverride="#C06C84" FontColorShadowOverride="#000000" ShadowOffsetXOverride="1" ShadowOffsetYOverride="1"/>
                        <OptionButton Name="ServerSelection"
                                      HorizontalExpand="True" />
                    </BoxContainer>
                    <Control MinSize="0 2" />
                    <BoxContainer Name="AddressContainer"
                                  Orientation="Horizontal"
                                  SeparationOverride="4"
                                  Visible="False">
                        <Label Text="Address: " FontColorOverride="#C06C84" FontColorShadowOverride="#000000" ShadowOffsetXOverride="1" ShadowOffsetYOverride="1"/>
                        <LineEdit Name="AddressBoxProtected"
                                  PlaceHolder="127.0.0.1:1212"
                                  HorizontalExpand="True" />
                    </BoxContainer>
                    <Control MinSize="0 2" />
                    <Button Name="ConnectButtonProtected"
                            Text="Connect"
                            TextAlign="Center" />
                    <Control MinSize="0 2" />
                    <Button Name="QuitButtonProtected"
                            Text="Quit"
                            TextAlign="Center" />
                </BoxContainer>
                <Control MinHeight="128"></Control>

                <BoxContainer Name="Notices" Orientation="Vertical"
                              SeparationOverride="4">
                    <Label Name="DebugWarningLabel"
                           Text="OpenDream was compiled in the Debug .NET configuration. This will heavily impact performance!"
                           FontColorOverride="#FF1111"
                           HorizontalAlignment="Center"
                           Visible="False"/>
                </BoxContainer>
            </BoxContainer>
            <Label Name="VersionLabel" Text="Version 1.1" FontColorOverride="#ffee00" Margin="0 0 10 10"/>
        </LayoutContainer>
    </PanelContainer>
</Control>
